      <Textarea label="Motivo de consulta" value={f.motivoConsulta} onChange={u('motivoConsulta')} style={{ minHeight: 70 }} />
      <Select label="Diagnóstico DSM-5 / CIE-11" value={f.diagnosis} onChange={u('diagnosis')}>
